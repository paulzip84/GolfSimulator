DATAGOLF_API_KEY=replace_with_your_datagolf_api_key
DATAGOLF_BASE_URL=https://feeds.datagolf.com
HTTP_TIMEOUT_SECONDS=20
DEFAULT_SIMULATIONS=1000000
LEARNING_DATABASE_PATH=.pga_sim_learning.sqlite3

# Auth options: none | basic_auth | shared_token | cloudflare_access
APP_AUTH_MODE=none
# Comma-separated path prefixes that bypass auth checks.
APP_AUTH_EXEMPT_PATHS=/health

# Basic auth mode (works on Render default domain)
APP_AUTH_BASIC_USERNAME=
APP_AUTH_BASIC_PASSWORD=
# basic_auth role: user | admin
APP_AUTH_BASIC_ROLE=admin

# Shared token mode
APP_AUTH_SHARED_TOKEN=
# shared_token role: user | admin
APP_AUTH_SHARED_TOKEN_ROLE=admin

# Authorization policy filters (optional)
AUTH_ALLOWED_EMAILS=
AUTH_ALLOWED_EMAIL_DOMAINS=
AUTH_ADMIN_EMAILS=
AUTH_ADMIN_EMAIL_DOMAINS=
AUTH_ADMIN_SUBJECTS=

# Cloudflare Access mode
CLOUDFLARE_ACCESS_TEAM_DOMAIN=
CLOUDFLARE_ACCESS_AUDIENCE=
